# apps/web (Next.js frontend) environment.
# Copy to .env.local and adjust as needed.

# Base URL of the project's OWN API gateway (@pma/api). The frontend talks
# EXCLUSIVELY to this endpoint and never to an upstream platform (Requirement
# 9.1). Defaults to http://localhost:4000 when unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Bearer token for user-scoped resources (watchlist, alerts). These endpoints
# require authentication (Requirement 9.4); the frontend sends this as
# `Authorization: Bearer <token>`. Real login is OUT OF SCOPE for v1 — providing
# a token here simply enables the watchlist UI for local/dev use. Leave unset to
# render the watchlist's "auth required" state instead.
NEXT_PUBLIC_API_TOKEN=
