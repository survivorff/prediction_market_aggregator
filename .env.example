# Local development environment variables (copy to .env and adjust as needed).
# These match the docker-compose.yml defaults.

# Postgres + TimescaleDB
DATABASE_URL=postgres://pma:pma@localhost:5432/pma

# Redis (hot cache + pub/sub)
REDIS_URL=redis://localhost:6379

# API gateway
API_PORT=4000

# Allowed browser origin(s) for CORS. The web frontend runs on a different
# origin than the gateway, so cross-origin fetches need this. "*" reflects any
# origin; otherwise a comma-separated allow-list. Defaults to the local Next.js
# dev origin when unset.
CORS_ORIGIN=http://localhost:3000

# Web frontend (apps/web): base URL of the project's OWN API gateway. The
# frontend talks ONLY to this endpoint, never to upstream platforms (Req 9.1).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Ingestion runner (@pma/ingestion) — pulls live data from the adapters.
INGEST_INTERVAL_MS=60000      # metadata re-sync cadence
POLL_INTERVAL_MS=15000        # price-poll cadence for non-WebSocket sources
HEALTH_INTERVAL_MS=5000       # WebSocket disconnect-check cadence
REQUEST_TIMEOUT_MS=10000      # per-request fetch timeout (fail fast if upstream is unreachable)
MATCH_MAX_MARKETS=300         # max unlinked markets matched per cycle (same-question matching)
# Predict.fun mainnet API key (x-api-key). When unset, the public testnet base
# URL is used (no key required).
PREDICTFUN_API_KEY=
